<?xml version="1.0" encoding="utf-8"?>
<!-- CardView gives rounded corners + shadow for each Pokemon row -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <!-- Row content: PokeDex No. | Image | Name -->
    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Pokedex number on far left -->
        <TextView
            android:id="@+id/pokemonDex"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center" />

        <!-- Small sprite after Dex No. -->
        <ImageView
            android:id="@+id/pokemonImage"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerInside"
            android:contentDescription="Pokemon sprite"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="20dp" />

        <!-- Text column: name (large) takes up rest of space on right -->
        <TextView
            android:id="@+id/pokemonName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121" />

    </LinearLayout>

</androidx.cardview.widget.CardView>